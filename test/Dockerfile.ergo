FROM ghcr.io/ergochat/ergo:v2.17.0

# The ergo image is Alpine-based; install nc for the healthcheck
RUN apk add --no-cache netcat-openbsd 2>/dev/null || true

COPY ergo/ircd.yaml /ircd/ircd.yaml
COPY ergo/fullchain.pem /ircd/fullchain.pem
COPY ergo/privkey.pem /ircd/privkey.pem

EXPOSE 6667 6697

WORKDIR /ircd

CMD ["ergo", "run", "--conf", "/ircd/ircd.yaml"]
